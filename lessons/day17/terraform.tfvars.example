#############################################
# Terraform Variable Values (terraform.tfvars)
#############################################
# Copy this file to terraform.tfvars and
# customize values as needed before deployment
#############################################

#############################################
# AWS Region Configuration
#############################################

# AWS region where all resources will be created
aws_region = "us-east-1"

#############################################
# Application Configuration
#############################################

# Name of the Elastic Beanstalk application
# Used as a prefix for all related resources
app_name = "my-app-bluegreen"

#############################################
# Elastic Beanstalk Platform Configuration
#############################################

# Solution stack (platform) for Elastic Beanstalk
# To view available stacks, run:
# aws elasticbeanstalk list-available-solution-stacks --region us-east-1
solution_stack_name = "64bit Amazon Linux 2023 v6.2.0 running Node.js 20"

#############################################
# EC2 Instance Configuration
#############################################

# EC2 instance type for both Blue and Green environments
# Common options: t3.micro, t3.small, t3.medium
instance_type = "t3.micro"

#############################################
# Resource Tagging Configuration
#############################################

# Tags applied to all Terraform-managed resources
tags = {
  Project     = "BlueGreenDeployment"
  Environment = "Demo"
  ManagedBy   = "Terraform"
  Owner       = "YourName"
}
